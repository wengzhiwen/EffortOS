  "help": {
    "title": "使用指南",
    "quick_start": "快速开始",
    "step1": "设置运动参数 — 前往设置页面，填写 FTP（骑行）、阈值心率（LTHR）和最大心率",
    "step2": "上传运动数据 — 在活动页面上传 TCX/GPX 文件，系统自动识别运动类型",
    "step3": "查看训练指标 — 仪表盘和活动详情页自动展示训练负荷分析",
    "step4": "获取 AI 建议 — AI 教练基于你的训练数据生成个性化建议",
    "metrics_explanation": "核心指标说明",
    "metric_col": "指标",
    "full_name_col": "全称",
    "meaning_col": "含义",
    "tss_desc": "训练压力分数。衡量单次训练对身体造成的负荷量。100 TSS 约等于 1 小时的阈值强度训练。基于功率（有 FTP 时）或心率计算。",
    "ctl_desc": "慢性训练负荷。42 天 TSS 的指数加权移动平均，反映长期体能水平。CTL 越高，说明近期训练量越大，体能基础越扎实。",
    "atl_desc": "急性训练负荷。7 天 TSS 的指数加权移动平均，反映短期疲劳程度。训练后 ATL 会快速上升。",
    "tsb_desc": "训练压力平衡 = CTL - ATL。正值表示恢复充分、状态好（适合比赛）；负值表示疲劳累积（适合训练期）。一般 -10 到 +10 之间为最佳比赛状态。",
    "np_desc": "标准化功率。考虑了骑行中加减速、间歇等因素后的等效持续功率。比平均功率更能反映真实强度。",
    "if_desc": "强度因子 = NP / FTP。反映本次训练相对于个人阈值功率的强度。IF > 1.0 表示超过阈值强度。",
    "vi_desc": "变异性指数 = NP / 平均功率。VI = 1.0 表示完美匀速（如计时赛），值越大表示骑行节奏变化越大。",
    "ef_desc": "效率因子 = NP / 平均心率。衡量在给定心率下产生的功率效率。EF 随训练提升，是衡量体能进步的好指标。",
    "intensity_level_desc": "基于强度因子（IF）自动评级：恢复（<0.65）、有氧耐力（<0.80）、节奏（<0.90）、阈值（<1.05）、VO2max（≥1.05）。帮助快速判断训练强度。",
    "zone_explanation": "分区说明",
    "hr_zones_title": "心率分区（Joe Friel 5 区）",
    "hr_zones_desc": "基于阈值心率（LTHR）自动推算。需要在设置页面配置各运动类型的 LTHR。",
    "zone_col": "分区",
    "range_col": "范围",
    "usage_col": "用途",
    "pw_zones_title": "功率分区（Coggan 7 区）",
    "pw_zones_desc": "基于 FTP 自动推算。需要在设置页面配置骑行 FTP。",
    "file_formats": "支持的文件格式",
    "tcx_title": "TCX (Garmin)",
    "tcx_desc": "Garmin Training Center XML 格式。包含心率、功率、速度、踏频、海拔等完整时间序列数据。",
    "gpx_title": "GPX",
    "gpx_desc": "GPS Exchange Format。支持 Garmin 扩展数据（心率、功率、踏频）。GPS 轨迹 + 扩展指标。",
    "feature_guide": "功能指南",
    "best_efforts_title": "Best Efforts 最佳表现",
    "best_efforts_desc": "系统自动计算每次活动中 5 秒 ~ 60 分钟各时间窗口的峰值功率和峰值心率。活动列表中金色 PB 标记表示该活动刷新了对应窗口的历史最佳。",
    "compare_title": "活动对比",
    "compare_desc": "选择两个活动进行横向对比，查看指标差异和趋势变化。前往活动对比页面。",
    "weekly_report_title": "AI 训练周报",
    "weekly_report_desc": "仪表盘底部的「AI 训练周报」按钮可一键生成本周训练报告。AI 教练会基于训练数据、最佳表现、强度分布等生成个性化分析和建议。也可在 AI 教练页面向教练提问。",
    "power_curve_title": "功率曲线 (Power Curve)",
    "power_curve_desc": "活动详情页展示功率曲线对比图：蓝色填充线为历史各时间窗口的峰值功率/心率，橙色虚线为当前活动的表现。直观了解本次训练与历史最佳的差距。",
    "fitness_trend_title": "体能趋势",
    "fitness_trend_desc": "仪表盘提供两个趋势图表：NP / 效率因子(EF) 双轴折线图跟踪功率效率变化；训练强度分布图展示 TSS 和强度因子(IF) 的关系。帮助你纵向评估体能进步。",
    "export_title": "数据导出",
    "export_desc": "活动列表页支持将活动数据导出为 CSV 或 JSON 格式，便于在其他工具中分析。支持按运动类型、日期范围和强度等级筛选后导出。",
    "search_sort_title": "搜索与排序",
    "search_sort_desc": "活动列表支持按名称关键词搜索，以及按日期、上传时间、名称排序。",
